{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BEA Commercial Lesson",
  "type": "object",
  "required": [
    "lesson_id",
    "cefr_level",
    "lesson_title",
    "learning_objective",
    "learner_facing_explanation",
    "complete_teaching_input",
    "examples",
    "interactive_practice",
    "correct_answers",
    "distractors",
    "instant_feedback",
    "teacher_notes",
    "homework_task",
    "assessment_task",
    "rubric",
    "speaking_task",
    "writing_task",
    "listening_audio",
    "visual_activity_cards",
    "downloadables",
    "completion_rule"
  ],
  "properties": {
    "lesson_id": {"type": "string"},
    "cefr_level": {"enum": ["A1", "A2", "B1", "B2", "C1", "C2"]},
    "lesson_title": {"type": "string"},
    "learning_objective": {"type": "string"},
    "learner_facing_explanation": {"type": "string"},
    "complete_teaching_input": {"type": "string"},
    "examples": {"type": "array"},
    "interactive_practice": {"type": "array"},
    "correct_answers": {"type": "object"},
    "distractors": {"type": "array"},
    "instant_feedback": {"type": "object"},
    "teacher_notes": {"type": "string"},
    "homework_task": {"type": "string"},
    "assessment_task": {"type": "object"},
    "rubric": {"type": "object"},
    "speaking_task": {"type": "string"},
    "writing_task": {"type": "string"},
    "listening_audio": {"type": "object"},
    "visual_activity_cards": {"type": "array"},
    "downloadables": {"type": "object"},
    "completion_rule": {"type": "object"}
  }
}
