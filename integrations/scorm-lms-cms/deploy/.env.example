# ════════════════════════════════════════════════════════════
# Docker Compose deployment secrets — copy to deploy/.env
# NEVER commit deploy/.env to version control.
# ════════════════════════════════════════════════════════════

# PostgreSQL
POSTGRES_USER=lea_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=lea_platform

# Database TLS/SSL: keep false for the bundled Docker Postgres; set true for managed cloud Postgres when required.
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=false

# JWT — generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_64_CHAR_HEX
JWT_EXPIRES_IN=8h

# Public origin of the frontend (for CORS)
ALLOWED_ORIGINS=http://localhost:8080

# Rate limiting
RATE_LIMIT_MAX=200

# Logging
LOG_LEVEL=info
