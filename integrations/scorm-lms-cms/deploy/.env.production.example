# BEA production environment template v2.0
NODE_ENV=production
PUBLIC_APP_URL=https://www.londonenglishacademy.com
API_PUBLIC_URL=https://api.londonenglishacademy.com
ALLOWED_ORIGINS=https://www.londonenglishacademy.com,https://admin.londonenglishacademy.com
PORT=4000

# Database
POSTGRES_DB=lea
POSTGRES_USER=lea_user
POSTGRES_PASSWORD=replace_me
DATABASE_URL=postgres://lea_user:replace_me@postgres:5432/lea
DATABASE_SSL=false
DB_POOL_MAX=20

# Security
JWT_SECRET=replace_with_64_character_random_secret
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# Redis
REDIS_URL=redis://redis:6379

# Object storage / CDN
S3_PROVIDER=s3-compatible
S3_ENDPOINT=https://s3.example.com
S3_REGION=auto
S3_BUCKET=lea-production-assets
S3_ACCESS_KEY_ID=replace_me
S3_SECRET_ACCESS_KEY=replace_me
CDN_PUBLIC_BASE_URL=https://cdn.londonenglishacademy.com
SIGNED_URL_TTL_SECONDS=900

# Video provider
VIDEO_PROVIDER=heygen
HEYGEN_API_KEY=replace_me
VIDEO_COMPLETION_THRESHOLD_PERCENT=90

# Email provider
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=replace_me
SMTP_PASS=replace_me
EMAIL_FROM=British English Academy <no-reply@londonenglishacademy.com>

# Feature flags
ENABLE_SCORM_EXPORT=true
ENABLE_CMS_PUBLISHING=true
ENABLE_VIDEO_PROGRESS=true
ENABLE_RESOURCE_SIGNED_URLS=true
