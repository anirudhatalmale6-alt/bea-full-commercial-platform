# ============================================================
# British English Academy — Environment Variables Template
# Copy to .env and fill in values. NEVER commit .env to git.
# ============================================================

NODE_ENV=development
PORT=4000

# PostgreSQL
DATABASE_URL=postgresql://lea_user:CHANGE_ME@localhost:5432/lea_platform
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=false
DB_POOL_MAX=20

# JWT (generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=CHANGE_ME_64_CHAR_HEX
JWT_EXPIRES_IN=8h

# CORS — comma-separated origins
ALLOWED_ORIGINS=http://localhost:3000

# Rate limiting (requests per window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# Logging
LOG_LEVEL=info

# Optional: override canonical activity-bank CSV path. Leave blank to use ../data/BEA_Early_Years_Interactive_Activity_Bank_PreK_G3_v1_2.csv
# ACTIVITY_BANK_CSV=../data/BEA_Early_Years_Interactive_Activity_Bank_PreK_G3_v1_2.csv
